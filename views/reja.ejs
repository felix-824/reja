<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>REJA</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" 
    integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3"
     crossorigin="anonymous">
</head>
<body style="background-color: #b8bbd1;">
    <div class="container">
        <h1 class="display-4 text-center py-1">Reja va Maqsadlar</h1>

     <div class="jumbotron p-4 shadow-sm rounded-3 bg-light">
       <form id="create-form" action="/create-item" method="POST">

          <div class="d-flex align-items-center gap-2">
            <input
              id="create-field"
              name="reja" 
              autofocus
              autocomplete="off"
              class="form-control"
              type="text"
              placeholder="Masalan: Olma, Non..."
              style="flex: 1; border-radius: 10px; height: 45px;"
            >
            <button
              class="btn btn-primary"
              style="border-radius: 20px; height: 45px; padding: 0 20px;">
              Yangi Reja Qoshish
            </button>
          </div>
       </form>
      </div>

  

       <ul id="item-list" class="list-group pb-5">
        <% items.map(function(item)  { %>
           <li 
        class="list-group-item list-group-item-info d-flex aligin-items-center justify-content-between"
        >
        <span class="item-text"><%=item.reja%></span>
        <div>
          <button 
            data-id="<%=item._id%>" 
            class="edit-me btn btn-secondary btn-sm mr-1"
            >
            Ozgartirish
          </button>
          <button 
            data-id="<%=item._id%>" 
          class="delete-me btn btn-danger btn-sm">Ochirish</button>
        </div>
        </li>
        <% }) %>
       
       </ul>

        <button
          id="clean-all"
          class="btn btn-primary"
          style="border-radius: 20px ; border: 0px; height: 45px;  margin-top: 20px; background: #bf2c34;">
         Hamma Rejalarni O'chirish
        </button>

    </div> 
</body>
</html>